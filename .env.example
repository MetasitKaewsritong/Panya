# ========== Database & LLM Configuration ==========
# Postgres credentials (used by docker-compose.yml)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=plcnextdb

# Connection URL (uses the above credentials)
DATABASE_URL=postgresql://user:password@postgres:5432/plcnextdb

# Gemini 1.5 Flash Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=30

# PDF Page Image Context (Vision mode)
USE_PAGE_IMAGES=false
PAGE_IMAGE_DPI=150

# ========== Embeddings ==========
EMBED_MODEL=BAAI/bge-m3
EVAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAGAS_EMBED_MODEL_EVAL=sentence-transformers/all-MiniLM-L6-v2

# ========== RAGAS (LLM judge) - Using Gemini ==========
ENABLE_RAGAS_LLM=true
RAGAS_LLM_PROVIDER=gemini
RAGAS_LLM_MODEL=gemini-1.5-flash
RAGAS_LLM_TEMPERATURE=0.0
RAGAS_CONTEXTS_K=3
RAGAS_CONTEXT_MAX_CHARS=240
RAGAS_TIMEOUT=30
RAGAS_BUDGET_S=25
RAGAS_MAX_WORKERS=1
DEFAULT_FAST_RAGAS=true
ENABLE_BACKGROUND_RAGAS=true
EVAL_WITH_RAGAS=true
RAGAS_USE_GROUND_TRUTH_LOOKUP=true
RAGAS_GROUND_TRUTH_FILE=/app/data/Knowledge/golden_qa_fx485adp_ragas.json
RAGAS_GROUND_TRUTH_FUZZY=true
RAGAS_GROUND_TRUTH_FUZZY_THRESHOLD=0.88
RAGAS_USE_VISION_OCR_CONTEXT=true

# ========== Chunking (ใช้ค่าตามนี้ได้เลย) ==========
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MIN_CHUNK_LENGTH=30

# RERANK (ใช้ค่าตามนี้ได้เลย)
USE_RERANK_DEFAULT=true
RETRIEVE_LIMIT=50
# Keep Golden QA eval-only by default (do not retrieve into RAG answer context)
RETRIEVE_INCLUDE_GOLDEN_QA=false
RERANK_CANDIDATES_MAX=32
RERANK_TOPN=8
RERANK_BOOST_GOLDEN_QA=0.0

# ========== (ไม่บังคับ) ถ้าคุณต้องการใช้ OpenAI API ==========
# ถ้าจะใช้ ให้ลบเครื่องหมาย # ข้างหน้า แล้วใส่ "คีย์ลับ" ของคุณ
# !! ห้ามใส่คีย์ลับของคุณลงในไฟล์ .env.example ที่จะ commit ขึ้น Git !!
# OPENAI_API_KEY=sk-YOUR-SECRET-KEY-GOES-HERE
# OPENAI_MODEL=gpt-4o-mini
# RAGAS_LLM_PROVIDER=openai
